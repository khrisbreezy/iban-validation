{
  "name": "iban-validate",
  "version": "1.0.0",
  "description": "Comprehensive IBAN validator. Supports 116 country codes — all official ISO 13616 countries plus experimental African countries. Zero dependencies.",
  "keywords": [
    "iban",
    "banking",
    "finance",
    "validation",
    "payments",
    "sepa",
    "iso-13616"
  ],
  "homepage": "https://github.com/khrisbreezy/iban-validation#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/khrisbreezy/iban-validation.git"
  },
  "bugs": {
    "url": "https://github.com/khrisbreezy/iban-validation/issues"
  },
  "license": "MIT",
  "author": "Oyinlola Abolarin <khrstopherabolarin@gmail.com>",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "^1.6.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "sideEffects": false
}
